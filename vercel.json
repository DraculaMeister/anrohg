{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/auth",
      "dest": "api/index.js"
    },
    {
      "src": "/menu.html",
      "dest": "api/index.js"
    },
    {
      "src": "/(style.css|script.js|favicon.png)",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}